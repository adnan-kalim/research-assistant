# Copy this file to .env and fill in your values. .env is gitignored.

# Required for Phase 3+ (Q&A / synthesis) -- get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional overrides -- defaults shown
# REASONING_MODEL=claude-haiku-4-5
# EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# DATA_DIR=./data
# CHROMA_COLLECTION=papers

# Optional: raises your Semantic Scholar rate limit (works fine without one)
# S2_API_KEY=

# Optional: gets faster, less-throttled responses from OpenAlex
# CONTACT_EMAIL=you@example.com
